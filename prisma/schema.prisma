generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  FARMER
  CONSUMER
}

enum OrderStatus {
  PLACED
  ACCEPTED
  OUT_FOR_DELIVERY
  DELIVERED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  mobile    String?
  role      Role
  
  // Location info
  pincode   String?
  address   String?
  latitude  Float?
  longitude Float?
  
  crops     Crop[]
  farmerOrders    Order[] @relation("FarmerOrders")
  consumerOrders  Order[] @relation("ConsumerOrders")
  handlerOrders   Order[] @relation("HandlerOrders")
  
  farmerInquiries   ContactInquiry[] @relation("FarmerInquiries")
  consumerInquiries ContactInquiry[] @relation("ConsumerInquiries")
  
  answers         Answer[]
  
  consumerReviews Review[] @relation("ConsumerReviews")
  
  handoffRequests   DeliveryHandoff[] @relation("HandoffRequests")
  handoffAccepts    DeliveryHandoff[] @relation("HandoffAccepts")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Crop {
  id            String   @id @default(uuid())
  name          String
  quantityKg    Float
  basePrice     Float
  farmerPincode String?
  
  farmerId      String
  farmer        User     @relation(fields: [farmerId], references: [id])
  
  items         OrderItem[]
  inquiries     ContactInquiry[]
  reviews       Review[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([farmerId])
  @@index([quantityKg])
}

model PincodeLocation {
  id        String @id @default(uuid())
  pincode   String @unique
  latitude  Float
  longitude Float
}

model Order {
  id              String      @id @default(uuid())
  consumerId      String
  consumer        User        @relation("ConsumerOrders", fields: [consumerId], references: [id])
  
  farmerId        String
  farmer          User        @relation("FarmerOrders", fields: [farmerId], references: [id])
  
  status          OrderStatus @default(PLACED)
  
  totalAmount     Float
  deliveryCharge  Float
  
  deliveryTime    String?     // Morning / Afternoon / Evening
  deliveryAddress String?
  deliveryPincode String?
  contactNumber   String?
  
  // Delivery handoff: locked handler after farmer-to-farmer transfer
  deliveryHandlerId String?
  deliveryHandler   User?   @relation("HandlerOrders", fields: [deliveryHandlerId], references: [id])
  
  items           OrderItem[]
  review          Review?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([farmerId])
  @@index([consumerId])
  @@index([farmerId, status])
}

enum HandoffStatus {
  PENDING
  ACCEPTED
  LOCKED
  REJECTED
}

model DeliveryHandoff {
  id                String        @id @default(uuid())
  clusterPincode    String
  
  requestingFarmerId String
  requestingFarmer   User         @relation("HandoffRequests", fields: [requestingFarmerId], references: [id])
  
  acceptingFarmerId  String?
  acceptingFarmer    User?        @relation("HandoffAccepts", fields: [acceptingFarmerId], references: [id])
  
  status            HandoffStatus @default(PENDING)
  goodsSentByA      Boolean       @default(false)
  goodsSentByB      Boolean       @default(false)
  
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([requestingFarmerId])
  @@index([acceptingFarmerId])
  @@index([status])
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id])
  
  cropId    String
  crop      Crop   @relation(fields: [cropId], references: [id])
  
  quantity  Float
  price     Float
}

model Question {
  id        String   @id @default(uuid())
  text      String
  order     Int      @default(0) // To show in sequence
  answers   Answer[]
}

model Answer {
  id          String   @id @default(uuid())
  transcript  String   // The text converted from audio
  audioUrl    String?  // Path to saved audio file
  
  questionId  String
  question    Question @relation(fields: [questionId], references: [id])
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime @default(now())
}

model ContactInquiry {
  id          String   @id @default(uuid())
  consumerId  String
  consumer    User     @relation("ConsumerInquiries", fields: [consumerId], references: [id])
  
  farmerId    String
  farmer      User     @relation("FarmerInquiries", fields: [farmerId], references: [id])
  
  cropId      String?
  crop        Crop?    @relation(fields: [cropId], references: [id])
  
  quantity    Float?
  proposedPrice Float?
  deliveryAddress String?
  contactNumber   String?
  
  message     String
  status      String   @default("PENDING")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([farmerId])
  @@index([consumerId])
}

model Review {
  id          String   @id @default(uuid())
  rating      Int
  comment     String?
  
  cropId      String
  crop        Crop     @relation(fields: [cropId], references: [id])
  
  consumerId  String
  consumer    User     @relation("ConsumerReviews", fields: [consumerId], references: [id])
  
  orderId     String?  @unique
  order       Order?   @relation(fields: [orderId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([cropId])
  @@index([consumerId])
}

